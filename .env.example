# Telegram API Credentials
# Получить на https://my.telegram.org/apps
API_ID=your_api_id_here
API_HASH=your_api_hash_here

# Бот для автолайков
BOT_USERNAME=@leomatchbot

# LM Studio API
# Убедитесь, что LM Studio запущен локально на этом адресе
LM_STUDIO_API_URL=http://localhost:1234/api/v1/chat
LM_STUDIO_MODEL=mistral-7b-instruct-v0.1

# Минимальная длина описания профиля для анализа (символы)
MIN_PROFILE_LENGTH=30

# Задержка перед отправкой ответа (секунды)
RESPONSE_DELAY=1.5
